# Playoff Forensics - Environment Variables
# Copy to .env.local and fill in values

# Gemini API (free at https://aistudio.google.com/apikey)
# Powers: player social reactions, agent dispatches
GEMINI_API_KEY=

# Python Analytics API URL (default: http://localhost:8000)
# Powers: advanced stats, win probability
PYTHON_API_URL=http://localhost:8000
